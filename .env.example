# Core infrastructure
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/code_review
REDIS_URL=redis://redis:6379/0
CHROMA_URL=http://chromadb:8000

# GitHub App integration
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# GitHub App private key (PEM). Multi-line PEM may be supplied with literal "\n"
# escapes; the worker normalizes them. Required when USE_GITHUB_APP_AUTH=true.
GITHUB_PRIVATE_KEY=

# Worker GitHub authentication
# When true, the worker authenticates as the GitHub App using installation
# tokens (requires GITHUB_APP_ID + GITHUB_PRIVATE_KEY). When false, it uses the
# static GITHUB_TOKEN PAT below.
USE_GITHUB_APP_AUTH=false
# Token used by the worker to read PRs and publish review comments (PAT path).
GITHUB_TOKEN=
# Optional: override for GitHub Enterprise (e.g. https://github.example.com/api/v3)
GITHUB_API_URL=

# OpenAI integration (worker LLM review generation)
OPENAI_API_KEY=
# Model used for review generation (defaults to gpt-4o-mini if unset)
OPENAI_MODEL=gpt-4o-mini
# Optional: override base URL for OpenAI-compatible providers
OPENAI_BASE_URL=

# Orchestration: LangGraph is the default multi-step review workflow
# (retrieve_context -> analyze_security/performance/logic -> synthesize_review).
# Set to false to use the legacy inline pipeline instead.
USE_LANGGRAPH=true

# Postgres (used by the postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=code_review

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# OpenTelemetry / Jaeger distributed tracing
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_INSECURE=true
# Optional override; defaults to ai-code-review-api / ai-code-review-worker
OTEL_SERVICE_NAME=

# Worker Prometheus metrics exporter
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=9100

# MLflow experiment tracking (worker review runs)
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=ai-code-review

# Frontend (browser) -> API base URL used by the dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
